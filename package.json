{
  "name": "chronotab",
  "displayName": "ChronoTab",
  "description": "A Visual Studio Code extension that tracks time spent per file across projects, with persistent session storage and a focus analytics dashboard.",
  "version": "2.0.0",
  "publisher": "Huerte",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "chronotab-sidebar",
          "title": "ChronoTab",
          "icon": "$(clock)"
        }
      ]
    },
    "views": {
      "chronotab-sidebar": [
        {
          "type": "webview",
          "id": "chronotab.timerView",
          "name": "Timer",
          "icon": "$(clock)"
        },
        {
          "type": "webview",
          "id": "chronotab.dashboardView",
          "name": "Dashboard",
          "icon": "$(graph)"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^18.x",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.x"
  }
}
