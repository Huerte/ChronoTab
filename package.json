{
  "name": "chronotab",
  "displayName": "ChronoTab",
  "description": "A VS Code extension that tracks per-file focus time across Git branches, with a real-time analytics dashboard, Pomodoro timer, idle detection, and CSV export.",
  "version": "3.0.0",
  "publisher": "Huerte",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "chronotab-sidebar",
          "title": "ChronoTab",
          "icon": "$(clock)"
        }
      ]
    },
    "views": {
      "chronotab-sidebar": [
        {
          "type": "webview",
          "id": "chronotab.timerView",
          "name": "Timer",
          "icon": "$(clock)"
        },
        {
          "type": "webview",
          "id": "chronotab.dashboardView",
          "name": "Dashboard",
          "icon": "$(graph)"
        }
      ]
    },
    "configuration": {
      "title": "ChronoTab",
      "properties": {
        "chronotab.idleTimeoutMinutes": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 60,
          "description": "Minutes of inactivity before ChronoTab automatically pauses background tracking."
        },
        "chronotab.pomodoroMinutes": {
          "type": "number",
          "default": 25,
          "minimum": 1,
          "maximum": 120,
          "description": "Default duration in minutes for the Pomodoro countdown timer."
        },
        "chronotab.trackGitBranch": {
          "type": "boolean",
          "default": true,
          "description": "Group tracked time by the active Git branch name."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^18.x",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.x"
  }
}
